<view class="tab-bar">
  <view wx:for="{{list}}" wx:key="index" class="tab-bar-item" data-path="{{item.pagePath}}" data-index="{{index}}" bindtap="switchTab">
    <!-- 首页图标 -->
    <view wx:if="{{item.icon === 'home'}}" class="icon-box">
      <view class="home-icon {{selected === index ? 'active' : ''}}">
        <view class="home-roof"></view>
        <view class="home-body"></view>
        <view class="home-door"></view>
      </view>
    </view>
    <!-- 我的图标 -->
    <view wx:else class="icon-box">
      <view class="profile-icon {{selected === index ? 'active' : ''}}">
        <view class="profile-head"></view>
        <view class="profile-body"></view>
      </view>
    </view>
    <text class="tab-text" style="color: {{selected === index ? selectedColor : color}}">{{item.text}}</text>
  </view>
</view>
