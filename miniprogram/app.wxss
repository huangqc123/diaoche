/**app.wxss - 吊装计算助手全局样式**/

page {
  background: #F2F3F5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

.container {
  padding: 24rpx 30rpx;
  padding-bottom: 180rpx;
}

/* 卡片样式 */
.card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.05);
}

/* 输入组 */
.input-group {
  margin-bottom: 30rpx;
}

.input-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.input-label .label-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.input-label .label-unit {
  font-size: 24rpx;
  color: #999999;
}

.input-field {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333333;
  box-sizing: border-box;
}

.input-field-placeholder {
  color: #C8C8C8;
  font-size: 26rpx;
}

/* Picker 样式 */
.picker-field {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333333;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.picker-value {
  color: #E8402F;
  font-weight: 600;
  font-size: 32rpx;
}

.picker-arrow {
  margin-left: 12rpx;
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 12rpx solid #CCCCCC;
}

/* 主按钮 */
.btn-primary {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #E8402F, #FF6B57);
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(232, 64, 47, 0.3);
  border: none;
  letter-spacing: 4rpx;
  margin-top: 10rpx;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  opacity: 0.85;
}

/* 结果标题 */
.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.title-bar {
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(180deg, #E8402F, #FF6B57);
  border-radius: 4rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

/* 状态标签 */
.tag {
  display: inline-flex;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
  align-items: center;
}

.tag-success {
  background: #F0FFF0;
  color: #52C41A;
}

.tag-warning {
  background: #FFFBE6;
  color: #FAAD14;
}

.tag-danger {
  background: #FFF2F0;
  color: #FF4D4F;
}

.tag-info {
  background: #E6F7FF;
  color: #1890FF;
}

/* 分隔线 */
.divider {
  height: 2rpx;
  background: #F0F0F0;
  margin: 24rpx 0;
}

/* Flex 工具类 */
.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 隐藏按钮默认样式 */
button {
  background: initial;
  padding: 0;
  margin: 0;
  line-height: inherit;
}

button::after {
  border: none;
}