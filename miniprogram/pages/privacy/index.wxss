.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.container {
  padding: 40rpx 36rpx 80rpx;
}

.doc-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1a1a;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.doc-update {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 36rpx;
}

.doc-intro {
  background: #fff;
  border-radius: 12rpx;
  padding: 28rpx;
  margin-bottom: 32rpx;
  font-size: 28rpx;
  color: #444;
  line-height: 1.8;
  border-left: 6rpx solid #E8402F;
}

.section {
  background: #fff;
  border-radius: 12rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 18rpx;
}

.section-body {
  font-size: 28rpx;
  color: #555;
  line-height: 1.9;
}

.doc-footer {
  margin-top: 40rpx;
  text-align: center;
  font-size: 24rpx;
  color: #aaa;
  line-height: 1.8;
}
