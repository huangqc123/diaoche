/* 页面滚动 */
.page-scroll {
  height: 100vh;
}

/* ===== 吊绳图示 ===== */
.diagram-card {
  padding: 20rpx;
}

.rope-diagram {
  width: 100%;
  height: 340rpx;
  position: relative;
  background: linear-gradient(180deg, #FFF5F3 0%, #FFFFFF 100%);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 滑轮 */
.d-hook-group {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 3;
}

.d-hook-ring {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #E8402F;
  border: 4rpx solid #C0301F;
}

.d-hook-body {
  width: 16rpx;
  height: 12rpx;
  background: #E8402F;
  border-radius: 0 0 8rpx 8rpx;
  margin-top: -2rpx;
}

/* 吊绳线 */
.d-sling-left {
  position: absolute;
  top: 60rpx;
  left: 50%;
  width: 4rpx;
  height: 160rpx;
  background: #555;
  transform-origin: top center;
  transform: translateX(-2rpx) rotate(22deg);
  z-index: 1;
}

.d-sling-right {
  position: absolute;
  top: 60rpx;
  left: 50%;
  width: 4rpx;
  height: 160rpx;
  background: #555;
  transform-origin: top center;
  transform: translateX(-2rpx) rotate(-22deg);
  z-index: 1;
}

/* 夹角标注 */
.d-angle-arc {
  position: absolute;
  top: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 40rpx;
  border: 3rpx solid #E8402F;
  border-top: none;
  border-radius: 0 0 30rpx 30rpx;
  z-index: 2;
}

.d-label-a {
  position: absolute;
  top: 105rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 28rpx;
  font-weight: 800;
  color: #E8402F;
  z-index: 2;
}

/* 吊物 */
.d-load {
  position: absolute;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 280rpx;
  height: 60rpx;
  background: linear-gradient(180deg, #333, #1A1A1A);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.d-load-text {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 700;
}

/* 分支数标注 */
.d-label-n {
  position: absolute;
  top: 120rpx;
  right: 60rpx;
  font-size: 24rpx;
  color: #1890FF;
  font-weight: 600;
  z-index: 3;
}

/* ===== 单位切换 ===== */
.unit-toggle {
  display: flex;
  background: #F0F0F0;
  border-radius: 6rpx;
  overflow: hidden;
}

.unit-btn {
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  color: #999;
  transition: all 0.2s;
}

.unit-btn.unit-active {
  background: #E8402F;
  color: #FFF;
  font-weight: 600;
}

/* ===== 表单 ===== */
.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.example-btn {
  margin-left: auto;
  font-size: 24rpx;
  color: #E8402F;
  padding: 8rpx 20rpx;
  border: 2rpx solid #E8402F;
  border-radius: 24rpx;
}

.structure-value {
  font-size: 28rpx;
}

.input-group.last {
  margin-bottom: 0;
}

/* ===== 按钮 ===== */
.btn-group {
  margin-bottom: 24rpx;
}

.btn-reset {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  margin-top: 20rpx;
  padding: 12rpx;
}

/* ===== 计算过程 ===== */
.result-card {
  background: linear-gradient(135deg, #FFF5F3, #FFFFFF);
}

.calc-steps {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.calc-step {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 20rpx;
  background: #FFFFFF;
  border-radius: 10rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}

.step-label {
  font-size: 26rpx;
  color: #666;
}

.step-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.step-value.highlight {
  color: #E8402F;
  font-size: 30rpx;
}

/* ===== 推荐卡片 ===== */
.recommend-card {
  background: linear-gradient(135deg, #F0FFF0, #FFFFFF);
  border: 2rpx solid #B7EB8F;
}

.recommend-main {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #52C41A;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.recommend-icon {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #FFF;
  font-weight: 800;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.recommend-info {
  display: flex;
  flex-direction: column;
}

.recommend-title {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 6rpx;
}

.recommend-diameter {
  font-size: 48rpx;
  font-weight: 900;
  color: #FFFFFF;
}

.recommend-details {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 2rpx solid #F0F0F0;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: #666;
}

.detail-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.detail-value.safe-margin {
  color: #52C41A;
  background: #F0FFF0;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.detail-value.alt-value {
  font-size: 26rpx;
  color: #1890FF;
}

/* 免责声明 */
.disclaimer {
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
}

.disclaimer text {
  font-size: 22rpx;
  color: #BBBBBB;
  line-height: 1.6;
}

/* 版权 */
.copyright {
  text-align: center;
  padding: 20rpx 0 40rpx;
}

.copyright text {
  font-size: 22rpx;
  color: #CCCCCC;
}
